    {
      "cell_type": "code",
      "source": [
        "#DecreaseKey\n",
        "\n",
        "def DecreaseKey(BQ, node, newKey):\n",
        "  if newKey > node.key:                   # Brodal only supports decreasing a key, not increasing\n",
        "    raise ValueError(\"New key must be smaller\")\n",
        "\n",
        "  node.key = newKey\n",
        "  parent = node.parent\n",
        "\n",
        "  if parent and node.key < parent.key:    # check if node is not a root & no order violation\n",
        "    parent.children.remove(node)          # node is no longer a child of parent\n",
        "    parent.rank -= 1                      # parent has one less child so decrease rank by 1\n",
        "    node.parent = None\n",
        "\n",
        "    if BQ.T2 is None:                     # if Tree 2 is empty, make node the root\n",
        "      BQ.T2 = node\n",
        "    else:\n",
        "      BQ.T2.children.append(node)         # else, add node to Tree 2\n",
        "      node.parent = BQ.T2                 # node's parent is root of Tree 2\n",
        "      BQ.T2.rank += 1                      # root has one more child now so increase rank\n",
        "\n",
        "  if node.key < BQ.min.key:               # if node is smaller than min, make node new min\n",
        "    BQ.min = node"
      ],
      "metadata": {
        "id": "2ajNlYCt8l2O"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#DeleteMin\n",
        "\n",
        "def DeleteMin(BQ):\n",
        "    if BQ.min is None:                #if queue empty, no min to remove\n",
        "        return None\n",
        "\n",
        "    extracted_min_node = BQ.min\n",
        "\n",
        "    children_to_meld = []\n",
        "    for child in extracted_min_node.children:\n",
        "        child.parent = None           #make min's children not point to it anymore\n",
        "        child.rank = 0\n",
        "        children_to_meld.append(child)\n",
        "\n",
        "    new_brodal_queue = MakeQueue()\n",
        "\n",
        "    if BQ.T2 is not None:            #if original queue had T2, meld queues\n",
        "        temp_Q2 = BrodalQueue(BQ.T2, None, BQ.T2)\n",
        "        new_brodal_queue = meld(new_brodal_queue, temp_Q2)\n",
        "\n",
        "    for child_node in children_to_meld:\n",
        "        temp_child_Q = BrodalQueue(child_node, None, child_node)\n",
        "        new_brodal_queue = meld(new_brodal_queue, temp_child_Q)\n",
        "\n",
        "    #update original queue with new info
        "    BQ.T1 = new_brodal_queue.T1\n",
        "    BQ.T2 = new_brodal_queue.T2\n",
        "    BQ.min = new_brodal_queue.min\n",
        "\n",
        "    return extracted_min_node\n"
      ],
      "metadata": {
        "id": "wbzZybme84Cy"
      },
      "execution_count": null,
      "outputs": []
    },
