      "cell_type": "code",
      "source": [
        "# Nodes\n",
        "class Node:\n",
        "  def __init__(self, key, data):\n",
        "    self.key = key\n",
        "    self.data = data\n",
        "    self.parent = None\n",
        "    self.children = []\n",
        "    self.rank = 0;\n",
        "\n",
        "  def __str__(self):\n",
        "    return f\"Key: {self.key}, Date: {self.data['Date']}\""
      ],
      "metadata": {
        "id": "SsWkpv9G6UoQ"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Trees\n",
        "class BrodalQueue:\n",
        "  def __init__(self, t1=None, t2=None, min_node=None):\n",
        "    self.T1 = t1            # tree w/ min\n",
        "    self.T2 = t2            # secondary tree\n",
        "    self.min = min_node"
      ],
      "metadata": {
        "id": "hOpjG_d-Bp65"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# MakeQueue\n",
        "\n",
        "def MakeQueue(data=None):\n",
        "  return BrodalQueue(data)"
      ],
      "metadata": {
        "id": "E-aelnri8lmI"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Insert\n",
        "\n",
        "# Insert(Q; e) inserts an element e into priority queue Q.\n",
        "# t(Q; e) is a special case of Meld where Q2 is a priority queue only containing one element.\n",
        "#  Meld(Q1; Q2) involves at most four trees; two for each queue. The tree having the new minimum\n",
        "# element as root becomes the new T1 tree. This tree was either the T1 tree of Q1 or of Q2. If\n",
        "# this tree is the tree of maximum rank we just add the other trees below this tree as described previously.\n",
        "# In this case no violating node is created so no transformation is done on the violating nodes.\n",
        "# Otherwise the tree of maximum rank becomes the new T2 tree and the remaining trees are added below this node as\n",
        "# described in Section 4.2, possibly delinking the new sons once if they have the same rank as t2.\n",
        "# The violations created by this are treated as described in Section 4.4.\n",
        "# The guides and arrays used at the old roots that now are linked below the new t2 node we just discard\n",
        "def insert(Q, e, data):\n",
        "  # We place the element into a node...\n",
        "  newNode = Node(e, data)\n",
        "  # ...then place that node into it's own Brodal Queue...\n",
        "  newQueue = BrodalQueue(newNode, None, newNode)\n",
        "  # ... which then is meld-ed with Q as Q1.\n",
        "  # Return the newly merged queue and the node that was just inserted\n",
        "  return meld(Q, newQueue), newNode"
      ],
      "metadata": {
        "id": "V_Cd86oJ-cVP"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# findMin\n",
        "\n",
        "def findMin(BQ):\n",
        "  if BQ.min is None:\n",
        "    return None\n",
        "  return BQ.min"
      ],
      "metadata": {
        "id": "mxEzxDk_8mUX"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# DUE TO LIMITATIONS IN PYTHON, WE WON'T USE THIS, PLACEHOLDERS AND BASIC IDEA\n",
        "# Meld\n",
        "# ti is the root of Ti.\n",
        "# The idea is to let t1 be the minimum element and to lazy merge the two trees T1 and T2 such that T2\n",
        "# becomes empty. Since t1 is the minimum element we can support FiFindMin in worst case constant time and\n",
        "# the lazy merging of the two trees corresponds intuitively to\n",
        "# performing Meld incrementally over the next sequence of operations.\n",
        "# The merging of the two trees is done by incrementally increasing the rank of t1 by moving\n",
        "# the sons of t2 to t1 such that T2 becomes empty and t1 becomes the node of maximum rank.\n",
        "# The actual details of implementing Meld follow in Section 4.5.\n",
        "# 4.5:\n",
        "#  Meld(Q1; Q2) involves at most four trees; two for each queue. The tree having the new minimum\n",
        "# element as root becomes the new T1 tree. This tree was either the T1 tree of Q1 or of Q2. If\n",
        "# this tree is the tree of maximum rank we just add the other trees below this tree as described previously.\n",
        "# In this case no violating node is created so no transformation is done on the violating nodes.\n",
        "# Otherwise the tree of maximum rank becomes the new T2 tree and the remaining trees are added below this node as\n",
        "# described in Section 4.2, possibly delinking the new sons once if they have the same rank as t2.\n",
        "# The violations created by this are treated as described in Section 4.4.\n",
        "# The guides and arrays used at the old roots that now are linked below the new t2 node we just discard\n",
        "\n",
        "def meld(Q1, Q2):\n",
        "  # Collect all potential tree roots from Q1 and Q2\n",
        "  all_potential_trees = [Q1.T1, Q1.T2, Q2.T1, Q2.T2]\n",
        "  # Filter out None values to get only actual Node objects\n",
        "  valid_trees = [t for t in all_potential_trees if t is not None]\n",
        "\n",
        "  # If no valid trees exist, return an empty BrodalQueue\n",
        "  if not valid_trees:\n",
        "    return MakeQueue() # MakeQueue creates BrodalQueue() which is fine now\n",
        "\n",
        "  # Find the tree with the minimum key among the valid trees\n",
        "  new_T1 = min(valid_trees, key=lambda node: node.key)\n",
        "\n",
        "  # Get the list of other trees (excluding new_T1)\n",
        "  remaining_trees = [t for t in valid_trees if t != new_T1]\n",
        "\n",
        "  new_T2 = None\n",
        "\n",
        "  if remaining_trees: # Only proceed if there are other trees to consider for T2 or linking\n",
        "      # Determine the maximum rank among all valid trees (including new_T1)\n",
        "      max_rank_among_all = max(t.rank for t in valid_trees)\n",
        "\n",
        "      if new_T1.rank >= max_rank_among_all:\n",
        "          # If new_T1 has the maximum rank, link all other trees as its children\n",
        "          for treeRoot in remaining_trees:\n",
        "              treeRoot.parent = new_T1\n",
        "              new_T1.children.append(treeRoot)\n",
        "          new_T2 = None\n",
        "      else:\n",
        "          # Otherwise, the tree of maximum rank among the remaining becomes the new T2 tree\n",
        "          new_T2 = max(remaining_trees, key=lambda node: node.rank)\n",
        "          remaining_trees.remove(new_T2) # Remove new_T2 from the list\n",
        "\n",
        "          # Link the remaining trees as children of new_T2\n",
        "          for treeRoot in remaining_trees:\n",
        "              treeRoot.parent = new_T2\n",
        "              new_T2.children.append(treeRoot)\n",
        "          # Violations created by this are treated as described in Section 4.4.\n",
        "          # VIOLATION FIX HERE (placeholder as per original code)\n",
        "          FOUR_POINT_4_PLACEHOLDER = 0\n",
        "\n",
        "  # Create and return the new BrodalQueue\n",
        "  # Assuming new_T1 is always the min of the resulting queue\n",
        "  return BrodalQueue(new_T1, new_T2, new_T1)"
      ],
      "metadata": {
        "id": "DlrEovok8mL4"
      },
      "execution_count": null,
      "outputs": []
